# =============================================================================
# Opensquad SaaS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://opensquad:${POSTGRES_PASSWORD}@postgres:5432/opensquad
POSTGRES_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
BACKEND_URL=https://opensquad.example.com
NEXT_PUBLIC_APP_URL=https://opensquad.example.com
NEXT_PUBLIC_BACKEND_URL=https://opensquad.example.com/api

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Plan Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_SCALE=price_...

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@opensquad.com

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=production
