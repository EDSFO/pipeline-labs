# =============================================================================
# Opensquad Backend — Environment Variables
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://opensquad:change_me_in_production@localhost:5432/opensquad

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_SCALE=price_...

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# Authentication
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@opensquad.com
